# Configuración de presentación · Sistema de Recomendación Vocacional UVG
# Copiar a .env.local para sobrescribir defaults en runtime.
# Todas las variables son opcionales: ausentes = defaults del perfil activo.

# ─────────────────────────────────────────────────────────────────────────────
# Override de vistas visibles (csv). Vacío o ausente = se usa el catálogo
# definido por el perfil en VITE_DEFAULT_STAKEHOLDER.
# IDs válidos: overview | financial | methodology | risk | sprints | sandbox | costs | annex
# ─────────────────────────────────────────────────────────────────────────────
VITE_VIEWS=

# Vista inicial al cargar. Debe pertenecer a las vistas visibles del perfil
# (o del override VITE_VIEWS). Si está vacía o no es válida, se usa la vista
# default del perfil.
# IDs válidos: overview | financial | methodology | risk | sprints | sandbox | costs | annex
VITE_DEFAULT_VIEW=

# ─────────────────────────────────────────────────────────────────────────────
# Modo explicativo completo. Solo aplica en perfil internal.
# 1 = muestra fórmulas formales (TMAR multiplicativa, EVM CPI/SPI/EAC,
#     EMV = P × I, etc.) en cards y secciones dedicadas.
# 0 = oculta esas fórmulas y deja solo la interpretación.
# Default: 0
# ─────────────────────────────────────────────────────────────────────────────
VITE_FULL_EXPLAIN=0

# ─────────────────────────────────────────────────────────────────────────────
# Modo presentación. Oculta controles auxiliares (p. ej. theme switcher).
# 1 = activo, 0 = desactivado.
# Default: 0
# ─────────────────────────────────────────────────────────────────────────────
VITE_PRESENTATION_MODE=0

# Mostrar sección Playground (componentes UI) en la sidebar.
# 1 = visible, 0 = oculto.
# Default: 0
VITE_PLAYGROUND=0

# Mostrar selector de tema en la sidebar.
# 1 = visible, 0 = oculto.
# Default: 1
VITE_THEME_SWITCHER=1

# Marca opcional para el header (texto breve, p. ej. "UVG · Admisiones").
# Vacío = sin marca adicional.
VITE_BRAND_LABEL=
